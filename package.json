{
  "name": "linkedin-pdf-resume-builder",
  "version": "1.0.0",
  "private": true,
  "description": "Upload a LinkedIn PDF export, convert it into JSON Resume, and render an ATS-friendly PDF.",
  "scripts": {
    "postinstall": "node scripts/workers-ci-postinstall.mjs",
    "dev": "next dev",
    "build": "next build",
    "build:worker": "npx opennextjs-cloudflare build",
    "start": "next start",
    "preview": "npm run build:worker && opennextjs-cloudflare preview",
    "deploy": "npm run build:worker && npm run deploy:worker",
    "deploy:worker": "opennextjs-cloudflare deploy",
    "upload:worker-version": "wrangler versions upload",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts",
    "lint": "eslint .",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "next": "^16.2.4",
    "pdf-parse": "^2.4.5",
    "pdfjs-serverless": "^1.2.2",
    "puppeteer": "^24.41.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@cloudflare/puppeteer": "^1.1.0",
    "@opennextjs/cloudflare": "1.19.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "^4.1.4",
    "esbuild": "^0.28.0",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.4",
    "jsdom": "^29.0.2",
    "lighthouse": "^13.1.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.4",
    "wrangler": "4.83.0"
  },
  "overrides": {
    "postcss": "^8.5.10",
    "ws": "^8.20.1"
  }
}
